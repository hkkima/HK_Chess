# Firebase 설정 (2차에서 사용). 실제 값은 .env 로 복사해 채우고 커밋하지 않음.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 저장소 선택: local(기본, MVP) | firebase(2차)
VITE_STORE=local

# 운영자 구글 로그인 허용 이메일(콤마 구분). 비우면 구글 로그인 누구나 운영자.
VITE_ADMIN_EMAILS=
